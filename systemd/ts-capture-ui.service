[Unit]
Description=TS Capture UI (FastAPI)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/ts-capture-ui
Environment="PYTHONUNBUFFERED=1"
Environment="TS_CAPTURE_DIR=/data/captures"
Environment="TS_BIND_HOST=0.0.0.0"
Environment="TS_BIND_PORT=8080"
ExecStart=/bin/sh -c '/opt/ts-capture-ui/.venv/bin/uvicorn app.main:app --host "$TS_BIND_HOST" --port "$TS_BIND_PORT"'
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
