[Unit]
Description=TS Capture UI (%i)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/ts-capture-ui/%i.env
WorkingDirectory=/opt/ts-capture-ui
ExecStart=/bin/sh -c '/opt/ts-capture-ui/.venv/bin/uvicorn app.main:app --host "$TS_BIND_HOST" --port "$TS_BIND_PORT"'
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
